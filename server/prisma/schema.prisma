// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

///////////////////////
// ENUMS
///////////////////////

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

///////////////////////
// CORE TENANT MODEL
///////////////////////

model School {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  classes   Class[]
}

///////////////////////
// USER SYSTEM
///////////////////////

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  role        Role

  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])

  // Relations
  studentProfile StudentProfile?
  parentLinks    ParentStudentRelation[] @relation("ParentRelation")
  teacherClasses Class[] @relation("TeacherClasses")

  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  grades Grade[]
  attendances Attendance[]
}

///////////////////////
// STUDENT PROFILE
///////////////////////

model StudentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])

  classId   String?
  class     Class?   @relation(fields: [classId], references: [id])

  parents   ParentStudentRelation[]

  attendances Attendance[]
  grades      Grade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

///////////////////////
// PARENT-STUDENT LINK
///////////////////////

model ParentStudentRelation {
  id        String   @id @default(cuid())

  parentId  String
  studentId String

  parent    User            @relation("ParentRelation", fields: [parentId], references: [id])
  student   StudentProfile  @relation(fields: [studentId], references: [id])

  relationType String? // e.g. father, mother, guardian

  createdAt DateTime @default(now())

  @@unique([parentId, studentId])
}

///////////////////////
// CLASS
///////////////////////

model Class {
  id        String   @id @default(cuid())
  name      String

  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])

  teacherId String?
  teacher   User?    @relation("TeacherClasses", fields: [teacherId], references: [id])

  students  StudentProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

///////////////////////
// ATTENDANCE
///////////////////////

model Attendance {
  id          String           @id @default(cuid())
  studentId   String
  student     StudentProfile   @relation(fields: [studentId], references: [id])

  date        DateTime
  status      AttendanceStatus

  markedById  String
  markedBy    User             @relation(fields: [markedById], references: [id])

  createdAt   DateTime @default(now())

  @@unique([studentId, date])
  @@index([date])
}

///////////////////////
// GRADES
///////////////////////

model Grade {
  id          String         @id @default(cuid())
  studentId   String
  student     StudentProfile @relation(fields: [studentId], references: [id])

  subject     String
  score       Float
  maxScore    Float?

  teacherId   String
  teacher     User           @relation(fields: [teacherId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId])
}

///////////////////////
// NOTIFICATIONS
///////////////////////

model Notification {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  title     String
  message   String
  read      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId, read])
}